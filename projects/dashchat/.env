# =============================================================================
# DashChat Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.

# -----------------------------------------------------------------------------
# App Database (PostgreSQL for DashChat's own data)
# -----------------------------------------------------------------------------
POSTGRES_USER=dashchat
POSTGRES_PASSWORD=61e5a51a6c5cb4c682bc334ad9777729
POSTGRES_DB=dashchat
DATABASE_URL=postgresql+asyncpg://dashchat:61e5a51a6c5cb4c682bc334ad9777729@postgres:5432/dashchat

# -----------------------------------------------------------------------------
# LLM Configuration (choose one)
# -----------------------------------------------------------------------------
# Option 1: OpenAI
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# Option 2: Ollama (local LLM)
OLLAMA_URL=http://192.168.0.92:11434
OLLAMA_MODEL=qwen3:32b

# Option 3: Anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# -----------------------------------------------------------------------------
# Vanna AI
# -----------------------------------------------------------------------------
# ChromaDB path for RAG storage (relative to backend container)
CHROMA_PERSIST_DIR=./chroma_data

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Secret key for encrypting database connection strings
SECRET_KEY=6fd9b9e35ebb37f03d86abff3b5a1ec659ca8053a59985c403f1a2a1e75980ed
# JWT secret for future auth
JWT_SECRET=fc252bab5fe71f16ca502e18903e183f19a42a0d88b44004e00414b454b8ae96

# -----------------------------------------------------------------------------
# Query Safety
# -----------------------------------------------------------------------------
# Max rows returned from user database queries
QUERY_ROW_LIMIT=1000
# Query timeout in seconds
QUERY_TIMEOUT=30

# -----------------------------------------------------------------------------
# Redis (for future pub/sub and caching)
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
